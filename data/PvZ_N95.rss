#include <avkon.hrh>
#include <avkon.rsg>

RESOURCE RSS_SIGNATURE
{
}

RESOURCE TBUF
{
    buf = "PvZ N95";
}

RESOURCE EIK_APP_INFO
{
    cba = r_pvz_cba;
    menubar = r_pvz_menubar;
}

RESOURCE CBA r_pvz_cba
{
    buttons =
    {
        CBA_BUTTON
        {
            id = EAknSoftkeyOptions;
