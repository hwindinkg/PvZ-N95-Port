// cstring stub for Symbian S60 3rd FP1 (abld GCCE).
// Just forwards to the SDK's <string.h>, which IS available under abld
// (only <cstring> was missing). Provides strcmp/memcpy/strlen/... in the
// global namespace.
//
// IMPORTANT: do NOT re-declare these as extern "C" here. The engine's
// Common.h defines inline strcmp/strlen/strstr/strcpy with C++ linkage;
// an extern "C" re-declaration clashed ("conflicting declaration").
// ResourceManager.h already pulls <string.h> + Common.h, so the only
// consumer (Resources.cpp) gets strcmp + memcpy regardless.
#ifndef PVZ_STUB_CSTRING
#define PVZ_STUB_CSTRING
#include <string.h>
#endif // PVZ_STUB_CSTRING
